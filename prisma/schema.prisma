datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Machine {
  id        String      @id @default(uuid())
  name      String      @unique
  location  String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  readings  Reading[]
  threshold Threshold?
  alerts    AlertLog[]
}

model Reading {
  id            String   @id @default(uuid())
  machineId     String
  machine       Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  temperature   Float
  humidity      Float
  timestamp     DateTime
  excelFileName String?
  uploadedAt    DateTime @default(now())
  alerts        AlertLog[]
}

model Threshold {
  id             String   @id @default(uuid())
  machineId      String   @unique
  machine        Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  maxTemperature Float    @default(40.0)
  minTemperature Float    @default(15.0)
  maxHumidity    Float    @default(80.0)
  minHumidity    Float    @default(20.0)
  updatedAt      DateTime @updatedAt
}

model AlertLog {
  id          String   @id @default(uuid())
  machineId   String
  machine     Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  readingId   String
  reading     Reading  @relation(fields: [readingId], references: [id], onDelete: Cascade)
  type        String   // "TEMPERATURE" or "HUMIDITY"
  value       Float
  threshold   Float
  timestamp   DateTime @default(now())
  emailSent   Boolean  @default(false)
  emailError  String?
}

model SystemSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}
